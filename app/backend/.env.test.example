# Backend — test environment (e2e). Copy to .env.test and adjust.
# Use a DEDICATED database, never the dev/prod one: the e2e suite writes to it.
DB_ENABLED=true
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_password
DB_NAME=diving_o_club_test

# JWT
JWT_SECRET=any_test_secret

# Mongo (logs) — dedicated test database
MONGO_URL=mongodb://localhost:27017/diving_o_club_test

# Seed password for the test database (required by the seed script)
SEED_PASSWORD=any_test_password
