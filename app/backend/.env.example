# Backend — NestJS
DB_ENABLED=true
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_password
DB_NAME=diving_o_club_dev

# Password used for the accounts created by the seed script.
# Required: the seed fails if it is not set. Use a strong value (never commit it).
SEED_PASSWORD=change_me_with_a_strong_password

# Staging database password, used by the db:reset script.
STAGING_DB_PASSWORD=change_me